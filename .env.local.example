# ── Google Sheets (Apps Script) ───────────────────────────────────────────────
# See scripts/append-sheet.gs for the code to deploy.
# Steps:
#  1. Open the Google Sheet → Extensions → Apps Script
#  2. Paste the contents of scripts/append-sheet.gs → Save
#  3. Deploy → New deployment → Web app
#     Execute as: Me | Who has access: Anyone
#  4. Copy the Web App URL and paste it below
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── Resend ────────────────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# While testing you can leave this as-is (sends from Resend's shared domain).
# For production, verify your domain in Resend and change to: xzvl.store <noreply@yourdomain.com>
RESEND_FROM=xzvl.store <onboarding@resend.dev>

# Base URL used to build links inside customer emails (e.g. "View My Orders").
NEXT_PUBLIC_SITE_URL=https://xzvl.store
